{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Arca Ensina Panel Protocol",
  "type": "object",
  "required": ["sections"],
  "properties": {
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "type", "rows"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "rows": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["drug_a", "drug_b", "formula"],
              "properties": {
                "drug_a": { "type": "string", "minLength": 1 },
                "drug_b": { "type": "string", "minLength": 1 },
                "formula": { "type": "string", "minLength": 1 },
                "notes": { "type": "string" },
                "route": { "type": "string" },
                "frequency": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "dose_limits": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["drug", "type", "max_dose", "unit"],
              "properties": {
                "drug": { "type": "string", "minLength": 1 },
                "type": { "type": "string", "enum": ["absolute", "per_kg"] },
                "max_dose": { "type": "string", "minLength": 1 },
                "unit": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": true
      }
    },
    "taper_schedules": { "type": "array" },
    "calculators": { "type": "array" },
    "reference_tables": { "type": "object" }
  },
  "additionalProperties": true
}
