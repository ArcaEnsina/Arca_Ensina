            "title": "Desmame: Morfina IV → Metadona VO",
            "type": "taper_schedule",
            "description": "Protocolo de desmame de morfina IV para metadona VO em 5-7 dias.",
            "steps": [
              {
                "day": 1,
                "action": "Calcular dose total de morfina IV nas últimas 24h",
                "formula": "dose_morfina_24h_mg",
                "notes": "Usar dose real administrada, não prescrita"
              },
              {
                "day": 1,
                "action": "Iniciar metadona VO",
                "dose": "1/3 da dose calculada de morfina",
                "formula": "dose_morfina_24h_mg / 3",
                "intervalo": "8h (3x/dia)",
                "notes": "Manter morfina IV em 50% da dose original"
              },
              {
                "day": 2,
                "action": "Reduzir morfina IV para 25%",
                "formula": "dose_morfina_original * 0.25",
                "notes": "Manter metadona"
              },
              {
                "day": 3,
                "action": "Suspender morfina IV",
                "notes": "Manter metadona. Monitorar sinais de abstinência (escala SOS)."
              },
              {
                "day": 4,
                "action": "Avaliar necessidade de ajuste de metadona",
                "notes": "Se SOS > 4, aumentar metadona em 25%"
              },
              {
                "day": 5,
                "action": "Iniciar redução de metadona",
                "formula": "dose_metadona_atual * 0.8",
                "notes": "Reduzir 20% a cada 2-3 dias"
              },
              {
                "day": 7,
                "action": "Avaliar descontinuação",
                "notes": "Se estável, reduzir para 1x/dia e suspender em 2-3 dias"
              }
            ],
            "monitoring": {
              "scale": "SOS (Sophia Observation withdrawal Symptoms)",
              "frequency": "A cada 4h durante desmame",
              "threshold": "SOS ≥ 4 → considerar aumento de dose"
            }
          },
