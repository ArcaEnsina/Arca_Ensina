              {"name": "peso", "label": "Peso do paciente (kg)", "unit": "kg"}
            ],
            "formula": "dose_fentanil_mcg_h * 24 * 0.1",
            "output_label": "Dose equivalente de Morfina IV (total/dia)",
            "output_unit": "mg/dia",
            "notes": "Fentanil 1 mcg/h ≈ 0.1 mg/dia de morfina IV"
          },
          {
            "id": "calc_midaz_diaz",
            "title": "Conversão Midazolam IV → Diazepam",
            "inputs": [
              {"name": "dose_midazolam_mg_h", "label": "Dose de Midazolam IV (mg/h)", "unit": "mg/h"},
              {"name": "peso", "label": "Peso do paciente (kg)", "unit": "kg"}
            ],
            "formula": "dose_midazolam_mg_h * peso * 0.6",
            "output_label": "Dose equivalente de Diazepam VO (mg/24h)",
            "output_unit": "mg/24h",
            "notes": "Diazepam tem meia-vida mais longa. Ajustar intervalo para 6/6h."
          },
          {
            "id": "calc_dexmed_clonidina",
            "title": "Conversão Dexmedetomidina → Clonidina",
            "inputs": [
              {"name": "dose_dexmed_mcg_kg_h", "label": "Dose de Dexmedetomidina (mcg/kg/h)", "unit": "mcg/kg/h"},
              {"name": "peso", "label": "Peso do paciente (kg)", "unit": "kg"}
            ],
            "formula": "dose_dexmed_mcg_kg_h * peso * 5",
            "output_label": "Dose equivalente de Clonidina VO/SL",
            "output_unit": "mcg/dose",
            "notes": "Clonidina 5x menos potente por via oral. Considerar meia-vida mais longa."
          },
          {
            "id": "calc_sedation_score",
            "title": "Meta de Sedação (RASS/SBS)",
            "inputs": [
              {"name": "rass_target", "label": "RASS alvo", "unit": "score", "min": -5, "max": 4},
              {"name": "current_rass", "label": "RASS atual", "unit": "score", "min": -5, "max": 4}
            ],
            "formula": "rass_target - current_rass",
            "output_label": "Ajuste necessário",
            "output_unit": "pontos",
            "interpretation": {
              "positive": "Paciente mais agitado que o alvo → aumentar sedação",
              "negative": "Paciente mais sedado que o alvo → reduzir sedação",
              "zero": "Dentro do alvo"
            }
          }
        ],
        "reference_tables": {
