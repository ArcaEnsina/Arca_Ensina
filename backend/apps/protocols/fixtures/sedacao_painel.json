            "type": "taper_schedule",
            "description": "Protocolo de desmame de midazolam contínuo.",
            "steps": [
              {
                "day": 1,
                "action": "Reduzir infusão em 20%",
                "formula": "dose_midazolam_atual * 0.8"
              },
              {
                "day": 2,
                "action": "Reduzir infusão em mais 20%",
                "formula": "dose_midazolam_atual * 0.8"
              },
              {
                "day": 3,
                "action": "Se < 0.05 mg/kg/h, tentar interromper",
                "notes": "Monitorar RASS/SBS. Se agitação, considerar troca para lorazepam intermitente."
              }
            ],
            "monitoring": {
              "scale": "RASS (Richmond Agitation-Sedation Scale)",
              "target": "RASS 0 a -2 (conforme indicação)",
              "frequency": "A cada 2h durante desmame"
            }
          }
        ],
        "calculators": [
          {
            "id": "calc_morfina_metadona",
